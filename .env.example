# =============================================================================
# Agile Octopus Daily Price Notifier — environment variables
# =============================================================================
# Copy this file to `.env` and fill in your values for local development.
# In production (GitHub Actions), these are set as repository secrets instead.
# Never commit `.env` to git — it should be in .gitignore.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# Comma-separated list of email recipients. BCC'd, so they don't see each other.
# Examples:
#   RECIPIENTS=yili@gmail.com
#   RECIPIENTS=yili@gmail.com,partner@gmail.com,backup@fastmail.com
RECIPIENTS=you@example.com

# SMTP server hostname.
#   Gmail:    smtp.gmail.com
#   Outlook:  smtp-mail.outlook.com
#   Fastmail: smtp.fastmail.com
SMTP_HOST=smtp.gmail.com

# SMTP port. Use 587 for STARTTLS (default), 465 for SSL/TLS.
SMTP_PORT=587

# SMTP username — usually your full email address.
SMTP_USER=you@gmail.com

# SMTP password.
# IMPORTANT: For Gmail, this MUST be an App Password (not your normal password).
# Generate at: https://myaccount.google.com/apppasswords
# Paste the 16-character code WITHOUT spaces.
SMTP_PASSWORD=abcdefghijklmnop


# -----------------------------------------------------------------------------
# OPTIONAL — leave commented out to use defaults
# -----------------------------------------------------------------------------

# Override the From: address. Defaults to SMTP_USER.
# SENDER_EMAIL=notifier@yourdomain.com

# Octopus Agile product code. Defaults to AGILE-24-10-01.
# Check current version: curl -s https://api.octopus.energy/v1/products/ | grep AGILE
# PRODUCT_CODE=AGILE-24-10-01

# Octopus tariff code. Format: E-1R-{PRODUCT_CODE}-{REGION_LETTER}
# Default is London (region C): E-1R-AGILE-24-10-01-C
# Region letters: A=Eastern, B=East Mids, C=London, D=Merseyside/N.Wales,
#                 E=W.Midlands, F=NE England, G=NW England, H=Southern,
#                 J=SE England, K=S.Wales, L=SW England, M=Yorkshire,
#                 N=S.Scotland, P=N.Scotland
# TARIFF_CODE=E-1R-AGILE-24-10-01-C

# IANA timezone. Defaults to Europe/London. Used for "tomorrow" computation.
# TIMEZONE=Europe/London
